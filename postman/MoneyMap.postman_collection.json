          "name": "List Categories",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const data = json.data || [];",
                  "const food = data.find(c => c.name === 'Food');",
                  "const salary = data.find(c => c.name === 'Salary');",
                  "const saving = data.find(c => c.type === 'SAVING');",
                  "const expense = data.find(c => c.type === 'EXPENSE');",
                  "const income = data.find(c => c.type === 'INCOME');",
                  "if (food) pm.collectionVariables.set('foodCategoryId', food.id);",
                  "if (salary) pm.collectionVariables.set('salaryCategoryId', salary.id);",
                  "if (saving) pm.collectionVariables.set('savingCategoryId', saving.id);",
                  "if (expense) pm.collectionVariables.set('expenseCategoryId', expense.id);",
                  "if (income) pm.collectionVariables.set('incomeCategoryId', income.id);"
                ]
